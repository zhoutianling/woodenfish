<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/page_top_padding"
        android:paddingBottom="@dimen/page_bottom_padding">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/record_title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/record_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/title_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/week_label_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_top_spacing"
            android:text="@string/weekly_practice"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/label_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/record_title_text" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/week_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/counter_medium_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/week_label_text"
            tools:text="@string/preview_week_count" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/record_panel"
            style="@style/Widget.WoodenFish.Card.Panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_32"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/week_count_text">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_20">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/current_data_label_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/current_data"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/button_text_size"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/record_today_card"
                    style="@style/Widget.WoodenFish.Card.Chip"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/metric_card_height"
                    android:layout_marginTop="@dimen/spacing_18"
                    android:layout_marginEnd="@dimen/spacing_8"
                    app:layout_constraintEnd_toStartOf="@id/record_total_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/current_data_label_text">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/record_today_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/body_text_size"
                        tools:text="@string/preview_record_today" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/record_total_card"
                    style="@style/Widget.WoodenFish.Card.Chip"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/metric_card_height"
                    android:layout_marginStart="@dimen/spacing_8"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/record_today_card"
                    app:layout_constraintTop_toTopOf="@id/record_today_card">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/record_total_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/body_text_size"
                        tools:text="@string/preview_record_total" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/record_streak_card"
                    style="@style/Widget.WoodenFish.Card.Chip"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/metric_card_height"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:layout_marginEnd="@dimen/spacing_8"
                    app:layout_constraintEnd_toStartOf="@id/record_auto_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/record_today_card">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/record_streak_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/body_text_size"
                        tools:text="@string/preview_record_streak" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/record_auto_card"
                    style="@style/Widget.WoodenFish.Card.Chip"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/metric_card_height"
                    android:layout_marginStart="@dimen/spacing_8"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/record_streak_card"
                    app:layout_constraintTop_toTopOf="@id/record_streak_card">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/record_auto_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/body_text_size"
                        tools:text="@string/preview_record_auto" />
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clear_today_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/primary_button_height"
            android:layout_marginTop="@dimen/spacing_28"
            android:backgroundTint="@color/accent_quiet"
            android:fontFamily="sans-serif-medium"
            android:text="@string/clear_today"
            android:textColor="@color/accent_on"
            android:textSize="@dimen/button_text_size"
            app:cornerRadius="28dp"
            app:elevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/record_panel"
            app:rippleColor="@color/primary_button_ripple" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
