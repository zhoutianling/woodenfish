<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:clipToPadding="false"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/contentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:id="@+id/pageTap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/todayLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="46dp"
                    android:text="@string/today_taps"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/todayCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:textColor="@color/text_primary"
                    android:textSize="58sp"
                    tools:text="@string/preview_today_count" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/peace_merit"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <FrameLayout
                    android:id="@+id/fishStage"
                    android:layout_width="320dp"
                    android:layout_height="320dp"
                    android:layout_marginTop="24dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <View
                        android:layout_width="286dp"
                        android:layout_height="286dp"
                        android:layout_gravity="center"
                        android:alpha="0.45"
                        android:background="@drawable/bg_fish_orbit" />

                    <View
                        android:layout_width="232dp"
                        android:layout_height="232dp"
                        android:layout_gravity="center"
                        android:alpha="0.72"
                        android:background="@drawable/bg_fish_orbit" />

                    <com.zero.woodenfish.TapEffectView
                        android:id="@+id/tapEffectView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <ImageView
                        android:id="@+id/fishImage"
                        android:layout_width="210dp"
                        android:layout_height="210dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/muyu_transparent" />

                    <TextView
                        android:id="@+id/meritText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="48dp"
                        android:layout_marginEnd="8dp"
                        android:alpha="0"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/merit_plus"
                        android:textColor="@color/text_primary"
                        android:textSize="25sp"
                        android:visibility="invisible" />
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/manualTapButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/accent_quiet"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/manual_tap"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    app:cornerRadius="28dp"
                    app:elevation="0dp"
                    app:rippleColor="#22000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/autoChip"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/autoSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            app:thumbTint="@color/switch_thumb"
                            app:trackTint="@color/switch_track" />

                        <TextView
                            android:id="@+id/autoStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/auto_off"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/autoIntervalText"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        tools:text="@string/preview_interval" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageRecord"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/record_title"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="46dp"
                    android:text="@string/weekly_practice"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/weekCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:textColor="@color/text_primary"
                    android:textSize="48sp"
                    tools:text="@string/preview_week_count" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/current_data"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/recordTodayText"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            tools:text="@string/preview_record_today" />

                        <TextView
                            android:id="@+id/recordTotalText"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            tools:text="@string/preview_record_total" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/recordStreakText"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            tools:text="@string/preview_record_streak" />

                        <TextView
                            android:id="@+id/recordAutoText"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            tools:text="@string/preview_record_auto" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clearTodayButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="28dp"
                    android:backgroundTint="@color/accent_quiet"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/clear_today"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    app:cornerRadius="28dp"
                    app:elevation="0dp"
                    app:rippleColor="#22000000" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/settings_title"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="46dp"
                    android:text="@string/sound_and_rhythm"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/sound_effect"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/wooden_fish_sound"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/soundSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/switch_thumb"
                            app:trackTint="@color/switch_track" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/haptic_feedback"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/soft_haptic"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/hapticSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/switch_thumb"
                            app:trackTint="@color/switch_track" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/auto_tap"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/settingsAutoSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                tools:text="@string/preview_interval" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/settingsAutoSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/switch_thumb"
                            app:trackTint="@color/switch_track" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/immersive_display"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/hide_status_bar"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/immersiveSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/switch_thumb"
                            app:trackTint="@color/switch_track" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:text="@string/auto_interval"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/intervalSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:valueFrom="0.5"
                    android:valueTo="2.0"
                    android:stepSize="0.5"
                    app:haloColor="#22FFFFFF"
                    app:labelBehavior="gone"
                    app:thumbColor="@color/accent_quiet"
                    app:trackColorActive="@color/accent_quiet"
                    app:trackColorInactive="@color/line_soft" />

                <TextView
                    android:id="@+id/intervalValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    tools:text="@string/preview_interval_scale" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/navTapItem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navTapIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/tab_tap"
                android:duplicateParentState="true"
                android:src="@drawable/ic_tab_tap"
                app:tint="@color/bottom_nav_item" />

            <TextView
                android:id="@+id/navTapLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:duplicateParentState="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/tab_tap"
                android:textColor="@color/bottom_nav_item"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRecordItem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navRecordIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/tab_record"
                android:duplicateParentState="true"
                android:src="@drawable/ic_tab_record"
                app:tint="@color/bottom_nav_item" />

            <TextView
                android:id="@+id/navRecordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:duplicateParentState="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/tab_record"
                android:textColor="@color/bottom_nav_item"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettingsItem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navSettingsIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/tab_settings"
                android:duplicateParentState="true"
                android:src="@drawable/ic_tab_settings"
                app:tint="@color/bottom_nav_item" />

            <TextView
                android:id="@+id/navSettingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:duplicateParentState="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/tab_settings"
                android:textColor="@color/bottom_nav_item"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
