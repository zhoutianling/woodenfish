<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.WoodenFish.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/line_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.WoodenFish.Card.Panel" parent="@style/Widget.WoodenFish.Card">
        <item name="cardBackgroundColor">@color/ink_soft</item>
        <item name="cardCornerRadius">18dp</item>
    </style>

    <style name="Widget.WoodenFish.Card.Chip" parent="@style/Widget.WoodenFish.Card">
        <item name="cardBackgroundColor">@color/ink_panel</item>
        <item name="cardCornerRadius">22dp</item>
    </style>

    <style name="TextAppearance.WoodenFish.BottomNavigation" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/bottom_navigation_label_text_size</item>
    </style>
</resources>
