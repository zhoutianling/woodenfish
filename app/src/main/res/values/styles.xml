<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.WoodenFish.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/line_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.WoodenFish.Card.Panel" parent="@style/Widget.WoodenFish.Card">
        <item name="cardBackgroundColor">@color/ink_soft</item>
        <item name="cardCornerRadius">18dp</item>
    </style>

    <style name="Widget.WoodenFish.Card.Chip" parent="@style/Widget.WoodenFish.Card">
        <item name="cardBackgroundColor">@color/ink_panel</item>
        <item name="cardCornerRadius">22dp</item>
    </style>

    <style name="TextAppearance.WoodenFish.BottomNavigation" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/bottom_navigation_label_text_size</item>
    </style>

    <style name="Widget.WoodenFish.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:width">@dimen/bottom_navigation_active_indicator_width</item>
        <item name="android:height">@dimen/bottom_navigation_active_indicator_height</item>
        <item name="marginHorizontal">@dimen/bottom_navigation_active_indicator_margin_horizontal</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.NavigationBarView.ActiveIndicator</item>
        <item name="android:color">@color/bottom_navigation_active_indicator</item>
    </style>
</resources>
